{
  "agentId": "macroeconomy-agent-v1",
  "domainKey": "macroeconomy",
  "contractVersion": "1.0.0",
  "outputSchemaVersion": "phase3-domain-agent-output/v1",
  "input": {
    "source": "foundation/data/normalized/phase2-normalized-sample.jsonl",
    "requiredFields": ["organizationId", "domainKey", "eventTime", "raw.id", "quality.confidence"],
    "filter": {
      "entityTypes": ["Observation", "Prediction"],
      "preferredSourceTypes": ["api", "csv"],
      "preferredSignalTypes": ["rate_signal"],
      "minimumConfidence": 0.7,
      "selectionLimit": 5
    }
  },
  "output": {
    "required": ["input", "scoring", "trace", "validation", "hypothesis", "prediction", "evidence"],
    "minimumEvidence": 3
  },
  "evaluation": {
    "minimumFilteredRows": 5,
    "minimumConfidence": 0.7,
    "requiredTraceRuleIds": ["domain_filter", "quality_sort", "macroeconomy_focus"]
  },
  "rules": [
    "focus on macroeconomic observations only",
    "prediction probability must be between 0 and 1",
    "return traceable evidence ids"
  ]
}
