{
  "agentId": "cyber-information-agent-v1",
  "domainKey": "cyber_information",
  "input": {
    "source": "foundation/data/normalized/phase2-normalized-sample.jsonl",
    "requiredFields": ["organizationId", "domainKey", "eventTime", "raw.id", "quality.confidence"]
  },
  "output": {
    "required": ["hypothesis", "prediction", "evidence"],
    "minimumEvidence": 3
  },
  "rules": [
    "focus on cyber_information observations only",
    "prediction probability must be between 0 and 1",
    "return traceable evidence ids"
  ]
}
