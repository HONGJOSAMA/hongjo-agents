{
  "schemaVersion": "phase3-domain-agent-output/v1",
  "contractVersion": "1.0.0",
  "requiredTopLevel": [
    "schemaVersion",
    "contractVersion",
    "agentId",
    "domainKey",
    "displayName",
    "generatedAt",
    "status",
    "input",
    "scoring",
    "trace",
    "validation",
    "rules",
    "hypothesis",
    "prediction",
    "evidence"
  ],
  "requiredInputFields": [
    "normalizedSource",
    "rowCount",
    "filteredRowCount",
    "entityTypeBreakdown",
    "sourceTypeBreakdown",
    "signalTypeBreakdown",
    "selectionPolicy",
    "selectedObservationIds"
  ],
  "requiredScoringFields": [
    "confidence",
    "signalStrength",
    "evidenceStrength",
    "riskLevel"
  ],
  "requiredTraceFields": [
    "selectedRuleIds",
    "fallbackUsed",
    "notes"
  ],
  "requiredValidationFields": [
    "minimumEvidence",
    "requiredFieldMissingCount",
    "schemaCheckPassed"
  ],
